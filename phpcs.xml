<?xml version="1.0"?>
<ruleset name="Mezzio Minimal">
    <description>Coding standard for Mezzio Minimal project</description>

    <!-- Show progress -->
    <arg value="p"/>
    <!-- Show colors -->
    <arg name="colors"/>
    <!-- Show sniff names -->
    <arg value="s"/>

    <!-- Check these paths -->
    <file>src</file>
    <file>public</file>
    <file>tests</file>

    <!-- Exclude vendor -->
    <exclude-pattern>vendor/*</exclude-pattern>

    <!-- Use PSR-12 standard -->
    <rule ref="PSR12"/>
</ruleset>
